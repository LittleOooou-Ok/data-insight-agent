# === 环境变量（含 API Key，必须忽略）===
.env

# === Python 编译缓存 ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# === 运行时数据（用户隐私 + 临时产物）===
data_insight/memory/
