memory/

# === 输出文件（图表、报告，运行时生成）===
data_insight/output/
!data_insight/output/.gitkeep

# === 数据库文件（运行时生成或用户真实数据）===
*.db
*.sqlite
*.sqlite3

# === 向量数据库 ===
chroma.sqlite3
*.bin

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === OS ===
.DS_Store
Thumbs.db

# === 虚拟环境 ===
venv/
.venv/
env/
