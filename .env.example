# DataInsight Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# === LLM 配置 ===
LLM_MODEL_ID=model_name
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# === 数据库配置 ===
# SQLite（本地测试，推荐）
DEFAULT_DB_TYPE=sqlite
SQLITE_DATABASE=./data_insight/test_retail.db

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=retail_db

# PostgreSQL（可选）
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your-password
# PG_DATABASE=ecommerce_db

# ClickHouse（可选）
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=9000
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=analytics

# === RAG 配置 ===
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
VECTOR_STORE_PATH=./data_insight/memory/vector_store
COLLECTION_NAME=data_insight_knowledge

# === 输出配置 ===
OUTPUT_DIR=./data_insight/output
CHARTS_DIR=./data_insight/output/charts
REPORTS_DIR=./data_insight/output/reports
